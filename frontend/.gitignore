# ============================================================
# .gitignore — список файлов, которые Git НЕ должен отслеживать
# ============================================================


# ------------------------------------------------------------
# СЕКРЕТЫ И КОНФИГУРАЦИЯ
# ------------------------------------------------------------
.env
.env.*          # .env.local, .env.production и т.д.
*.key
*.pem


# ------------------------------------------------------------
# PYTHON — временные файлы интерпретатора
# ------------------------------------------------------------

# Скомпилированный байткод Python (создаётся автоматически)
__pycache__/
*.py[cod]           # .pyc, .pyo, .pyd
*$py.class

# Виртуальное окружение — у каждого разработчика своё
venv/
.venv/
env/
.env/

# Файлы установки пакетов
*.egg-info/
dist/
build/
.eggs/

# Pytest — временные файлы тестов
.pytest_cache/
.coverage
htmlcov/


# ------------------------------------------------------------
# DJANGO — специфичные файлы
# ------------------------------------------------------------

# База данных SQLite — это локальный файл разработчика,
*.sqlite3
db.sqlite3

# Собранная статика (генерируется командой collectstatic)
staticfiles/
static_root/

# Медиафайлы пользователей (аватарки и т.д.)
media/

# Логи приложения
logs/
*.log


# ------------------------------------------------------------
# NODE.JS / FRONTEND
# ------------------------------------------------------------

# Папка с зависимостями — восстанавливается через npm install
node_modules/

# Папка со сборкой фронтенда
dist/
build/

# Кэш Vite
.vite/

# Кэш ESLint
.eslintcache


# ------------------------------------------------------------
# ОПЕРАЦИОННАЯ СИСТЕМА
# ------------------------------------------------------------


# Windows
Thumbs.db
Desktop.ini

# ------------------------------------------------------------
# РЕДАКТОРЫ КОДА
# ------------------------------------------------------------

# VSCode (некоторые настройки личные, некоторые — общие)
.vscode/settings.json      # личные настройки редактора
.vscode/launch.json        # личные настройки отладки
# .vscode/extensions.json  # список рекомендуемых расширений

# PyCharm / IntelliJ
.idea/

# Vim
*.swp
*.swo
